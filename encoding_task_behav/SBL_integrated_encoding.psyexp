      <CodeComponent name="code_trigger" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="import atexit&amp;#10;&amp;#10;mode = expInfo.get('mode', 'behavioral').lower()&amp;#10;&amp;#10;# =========================================&amp;#10;# OPM MODE&amp;#10;# =========================================&amp;#10;&amp;#10;if mode == 'opm':&amp;#10;&amp;#10;    import parallel&amp;#10;&amp;#10;    print(&quot;OPM mode ON&quot;)&amp;#10;&amp;#10;    pdev = parallel.Parallel()&amp;#10;&amp;#10;    dpx_base_address = 0&amp;#10;&amp;#10;    def trigger_internal(trigger_val):&amp;#10;        pdev.setData(trigger_val &amp; 255)&amp;#10;        core.wait(0.002)&amp;#10;        pdev.setData(0)&amp;#10;&amp;#10;    def dpx_trigger(trigger_val, addr=None):&amp;#10;        win.callOnFlip(trigger_internal, trigger_val)&amp;#10;&amp;#10;    def cleanup():&amp;#10;        pass&amp;#10;&amp;#10;# =========================================&amp;#10;# BEHAVIORAL MODE&amp;#10;# =========================================&amp;#10;&amp;#10;else:&amp;#10;&amp;#10;    print(&quot;Behavioral mode ON&quot;)&amp;#10;&amp;#10;    dpx_base_address = None&amp;#10;&amp;#10;    def dpx_trigger(trigger_val, addr=None):&amp;#10;        pass&amp;#10;&amp;#10;    def cleanup():&amp;#10;        pass&amp;#10;&amp;#10;# =========================================&amp;#10;# REGISTER CLEANUP&amp;#10;# =========================================&amp;#10;&amp;#10;atexit.register(cleanup)" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="import * as atexit from 'atexit';&amp;#10;if ((expInfo[&quot;meg_type&quot;] === &quot;squid&quot;)) {&amp;#10;    import {DPxClose, DPxGetDoutBuffBaseAddr, DPxOpen, DPxSelectDevice, DPxSetDoutBuff, DPxSetDoutSched, DPxSetDoutValue, DPxStartDoutSched, DPxStopDoutSched, DPxUpdateRegCache, DPxWriteRam, DPxWriteRegCacheAfterVideoSync} from 'pypixxlib/_libdpx';&amp;#10;    new DPxOpen();&amp;#10;    new DPxSelectDevice(&quot;PROPixxCtrl&quot;);&amp;#10;    new DPxStopDoutSched();&amp;#10;    new DPxUpdateRegCache();&amp;#10;    new DPxSetDoutValue(0, 16777215);&amp;#10;    new DPxUpdateRegCache();&amp;#10;    dpx_base_address = new DPxGetDoutBuffBaseAddr();&amp;#10;    function dpx_trigger(trigger_val, addr) {&amp;#10;        var buffer_dout;&amp;#10;        buffer_dout = [trigger_val, 0];&amp;#10;        new DPxSetDoutBuff(addr, 4);&amp;#10;        new DPxWriteRam(addr, buffer_dout);&amp;#10;        new DPxSetDoutSched(0, 100, &quot;hz&quot;, 2);&amp;#10;        new DPxStartDoutSched();&amp;#10;        new DPxWriteRegCacheAfterVideoSync();&amp;#10;    }&amp;#10;    function cleanup() {&amp;#10;        new DPxStopDoutSched();&amp;#10;        new DPxSetDoutValue(0, 16777215);&amp;#10;        new DPxUpdateRegCache();&amp;#10;        new DPxClose();&amp;#10;    }&amp;#10;} else {&amp;#10;    if ((expInfo[&quot;meg_type&quot;] === &quot;opm&quot;)) {&amp;#10;        import * as parallel from 'parallel';&amp;#10;        pdev = new parallel.Parallel();&amp;#10;        dpx_base_address = 0;&amp;#10;        function dpx_trigger(trigger_val, addr) {&amp;#10;            psychoJS.window.callOnFlip(trigger_internal, trigger_val);&amp;#10;        }&amp;#10;        function trigger_internal(trigger_val) {&amp;#10;            pdev.setData((trigger_val &amp; 255));&amp;#10;            core.wait(0.002);&amp;#10;            pdev.setData(0);&amp;#10;        }&amp;#10;        function cleanup() {&amp;#10;        }&amp;#10;    } else {&amp;#10;        function dpx_trigger(trigger_val, addr) {&amp;#10;            psychoJS.window.callOnFlip(print, `Trigger called:${trigger_val} at ${core.getTime()}`);&amp;#10;        }&amp;#10;        function cleanup() {&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;atexit.register(cleanup);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if (((image_scene.status === PsychoJS.Status.STARTED) &amp;&amp; (image_scene.frameNStart === frameN))) {&amp;#10;    dpx_trigger(current_trigger_value, dpx_base_address);&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="if image_integrated.status == STARTED and image_integrated.frameNStart == frameN:&amp;#10;&amp;#10;    dpx_trigger(current_trigger_value, dpx_base_address)" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if (((image_scene.status === PsychoJS.Status.STARTED) &amp;&amp; (image_scene.frameNStart === frameN))) {&amp;#10;    dpx_trigger(current_trigger_value, dpx_base_address);&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
