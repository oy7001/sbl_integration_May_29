      <CodeComponent name="code_end_inst" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="window.end_inst = undefined;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if (expInfo['group']==='A' &amp;&amp; expInfo['delay']==='short'){&amp;#10;    window.end_inst = 'Great job!\n\nTo continue to the next task, Press SPACEBAR, and then select &quot;OK&quot; in the prompted window - this will lead you to the next part of the experiment.';&amp;#10;    }else{&amp;#10;        window.end_inst = 'Great job! You are done with the first session of our experiment!\n\nIn three days, we will send you the link trhough Prolific massages to the second session of the experiment, and you will have 24 hours to complete it. If you would like to receive an email notification as well, please send us a massage with your email address.\n\nPress SPACEBAR and &quot;OK&quot; in the prompted window to receive the completion code for the current session.';&amp;#10;        }&amp;#10;    " valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if expInfo['group'] == 'A' and expInfo['delay'] == 'short':&amp;#10;    end_inst = (&amp;#10;        &quot;Great job!\n\n&quot;&amp;#10;        &quot;To continue to the next task, press SPACEBAR, and then select 'OK' in the prompted window &quot;&amp;#10;        &quot;- this will lead you to the next part of the experiment.&quot;&amp;#10;    )&amp;#10;else:&amp;#10;    end_inst = (&amp;#10;        &quot;Great job! You are done with the first session of our experiment!\n\n&quot;&amp;#10;        &quot;In three days, we will send you the link through Prolific messages to the second session of the experiment, &quot;&amp;#10;        &quot;and you will have 24 hours to complete it. If you would like to receive an email notification as well, &quot;&amp;#10;        &quot;please send us a message with your email address.\n\n&quot;&amp;#10;        &quot;Press SPACEBAR and 'OK' in the prompted window to receive the completion code for the current session.&quot;&amp;#10;    )" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
