        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if (expInfo['group']==='A' &amp;&amp; expInfo['delay']==='short'){&amp;#10;    completion_url = 'https://run.pavlovia.org/nitzanlubi/arithmetic_task_exp/?group=' &amp;#10;        + expInfo['group'] &amp;#10;        + '&amp;participant=' + expInfo['participant'] &amp;#10;        + '&amp;session=' + expInfo['session'] &amp;#10;        + '&amp;delay=' + expInfo['delay'];&amp;#10;    console.log('completion url:',completion_url);&amp;#10;//    window.location.href = completion_url;&amp;#10;    psychoJS.setRedirectUrls(completion_url, '');&amp;#10;    }else{&amp;#10;        completion_url = 'https://app.prolific.com/submissions/complete?cc=CUFOIWKV';&amp;#10;        console.log('completion url:',completion_url);&amp;#10;//        window.location.href = completion_url;&amp;#10;        psychoJS.setRedirectUrls(completion_url, '');&amp;#10;        }&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="if expInfo['group'] == 'A' and expInfo['delay'] == 'short':&amp;#10;    completion_url = (&amp;#10;        &quot;https://run.pavlovia.org/nitzanlubi/arithmetic_task_exp/?group=&quot;&amp;#10;        + expInfo['group']&amp;#10;        + &quot;&amp;participant=&quot; + expInfo['participant']&amp;#10;        + &quot;&amp;session=&quot; + expInfo['session']&amp;#10;        + &quot;&amp;delay=&quot; + expInfo['delay']&amp;#10;    )&amp;#10;else:&amp;#10;    completion_url = &quot;https://app.prolific.com/submissions/complete?cc=CUFOIWKV&quot;&amp;#10;&amp;#10;print(&quot;completion url:&quot;, completion_url)" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
