        <Param val="if ((key_related === &quot;q&quot;)) {&amp;#10;    text_inst_pause = &quot;Reminder:\n\nIf the scene and item are related, press Q\nIf they are unrelated, press P.\n\nPress ONLY AFTER the item and scene disappeared!\n\nPress SPACEBAR to resume.&quot;;&amp;#10;}&amp;#10;if ((key_related === &quot;p&quot;)) {&amp;#10;    text_inst_pause = &quot;Reminder:\n\nIf the scene and item are related, press P\nIf they are unrelated, press Q.\n\nPress ONLY AFTER the item and scene disappeared!\n\nPress SPACEBAR to resume.&quot;;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if key_related == 'q':&amp;#10;    text_inst_pause = (&amp;#10;        &quot;Reminder:\n\n&quot;&amp;#10;        &quot;If the scene and item are related, press Q\n&quot;&amp;#10;        &quot;If they are unrelated, press P.\n\n&quot;&amp;#10;        &quot;Press ONLY AFTER the item and scene disappeared!\n\n&quot;&amp;#10;        &quot;Press SPACEBAR to resume.&quot;&amp;#10;    )&amp;#10;&amp;#10;elif key_related == 'p':&amp;#10;    text_inst_pause = (&amp;#10;        &quot;Reminder:\n\n&quot;&amp;#10;        &quot;If the scene and item are related, press P\n&quot;&amp;#10;        &quot;If they are unrelated, press Q.\n\n&quot;&amp;#10;        &quot;Press ONLY AFTER the item and scene disappeared!\n\n&quot;&amp;#10;        &quot;Press SPACEBAR to resume.&quot;&amp;#10;    )" valType="extendedCode" updates="constant" name="Begin Routine"/>
