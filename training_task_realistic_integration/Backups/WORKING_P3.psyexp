        <Param val="# participant number&amp;#10;subnum = int(expInfo['participant'])&amp;#10;&amp;#10;# base order&amp;#10;labels = [&quot;JA&quot;, &quot;JB&quot;, &quot;UA&quot;, &quot;UB&quot;]&amp;#10;&amp;#10;# counterbalance order&amp;#10;shift = subnum % 4&amp;#10;ordered_labels = labels[shift:] + labels[:shift]&amp;#10;&amp;#10;print(&quot;Visualization order:&quot;, ordered_labels)" valType="extendedCode" updates="constant" name="Begin Experiment"/>
