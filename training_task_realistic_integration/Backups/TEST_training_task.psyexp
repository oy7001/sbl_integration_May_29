        <Param val="import * as random from 'random';&amp;#10;stimuli = [[&quot;TESTstimuli/TESTscenes/JA_1.png&quot;, &quot;Tulon&quot;], [&quot;TESTstimuli/TESTscenes/JB_1.png&quot;, &quot;Malbow&quot;], [&quot;TESTstimuli/TESTscenes/UA_1.png&quot;, &quot;Negvi&quot;], [&quot;TESTstimuli/TESTscenes/UB_1.png&quot;, &quot;Somar&quot;]];&amp;#10;Math.random.shuffle(stimuli);&amp;#10;[img1.image, label1.text] = stimuli[0];&amp;#10;[img2.image, label2.text] = stimuli[1];&amp;#10;[img3.image, label3.text] = stimuli[2];&amp;#10;[img4.image, label4.text] = stimuli[3];&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
