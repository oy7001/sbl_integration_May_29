        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="import * as random from 'random';&amp;#10;stimuli = [[&quot;TESTstimuli/TESTscenes/JA_3.png&quot;, &quot;Tulon&quot;], [&quot;TESTstimuli/TESTscenes/JB_3.png&quot;, &quot;Malbow&quot;], [&quot;TESTstimuli/TESTscenes/UA_3.png&quot;, &quot;Negvi&quot;], [&quot;TESTstimuli/TESTscenes/UB_3.png&quot;, &quot;Somar&quot;]];&amp;#10;Math.random.shuffle(stimuli);&amp;#10;[img1_2.image, label1_2.text] = stimuli[0];&amp;#10;[img2_2.image, label2_2.text] = stimuli[1];&amp;#10;[img3_2.image, label3_2.text] = stimuli[2];&amp;#10;[img4_2.image, label4_2.text] = stimuli[3];&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="import random&amp;#10;&amp;#10;# image + name pairs&amp;#10;stimuli = [&amp;#10;    (&quot;TESTstimuli/TESTscenes/JA_3.png&quot;, &quot;Tulon&quot;),&amp;#10;    (&quot;TESTstimuli/TESTscenes/JB_3.png&quot;, &quot;Malbow&quot;),&amp;#10;    (&quot;TESTstimuli/TESTscenes/UA_3.png&quot;, &quot;Negvi&quot;),&amp;#10;    (&quot;TESTstimuli/TESTscenes/UB_3.png&quot;, &quot;Somar&quot;)&amp;#10;]&amp;#10;&amp;#10;# randomize order&amp;#10;random.shuffle(stimuli)&amp;#10;&amp;#10;# assign to positions&amp;#10;img1_2.image, label1_2.text = stimuli[0]&amp;#10;img2_2.image, label2_2.text = stimuli[1]&amp;#10;img3_2.image, label3_2.text = stimuli[2]&amp;#10;img4_2.image, label4_2.text = stimuli[3]&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
