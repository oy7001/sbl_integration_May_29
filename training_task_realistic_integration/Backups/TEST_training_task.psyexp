        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="import * as random from 'random';&amp;#10;stimuli = [[&quot;TESTstimuli/TESTscenes/JA_1.png&quot;, &quot;Tulon&quot;], [&quot;TESTstimuli/TESTscenes/JB_1.png&quot;, &quot;Malbow&quot;], [&quot;TESTstimuli/TESTscenes/UA_1.png&quot;, &quot;Negvi&quot;], [&quot;TESTstimuli/TESTscenes/UB_1.png&quot;, &quot;Somar&quot;]];&amp;#10;Math.random.shuffle(stimuli);&amp;#10;img1_showALL.image = stimuli[0];&amp;#10;img2_showALL.image = stimuli[1];&amp;#10;img3_showALL.image = stimuli[2];&amp;#10;img4_showALL.image = stimuli[3];&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="import random&amp;#10;&amp;#10;# image + name pairs&amp;#10;stimuli = [&amp;#10;    (&quot;TESTstimuli/TESTscenes/JA_1.png&quot;, &quot;Tulon&quot;),&amp;#10;    (&quot;TESTstimuli/TESTscenes/JB_1.png&quot;, &quot;Malbow&quot;),&amp;#10;    (&quot;TESTstimuli/TESTscenes/UA_1.png&quot;, &quot;Negvi&quot;),&amp;#10;    (&quot;TESTstimuli/TESTscenes/UB_1.png&quot;, &quot;Somar&quot;)&amp;#10;]&amp;#10;&amp;#10;# randomize order&amp;#10;random.shuffle(stimuli)&amp;#10;&amp;#10;# assign to positions&amp;#10;img1_showALL.image = stimuli[0]&amp;#10;img2_showALL.image = stimuli[1]&amp;#10;img3_showALL.image = stimuli[2]&amp;#10;img4_showALL.image = stimuli[3]&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="setStimuli_3" valType="code" updates="None" name="name"/>
      </CodeComponent>
      <KeyboardComponent name="key_p1_compare_3" plugin="None">
        <Param val="'space'" valType="list" updates="constant" name="allowedKeys"/>
        <Param val="" valType="str" updates="constant" name="correctAns"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
