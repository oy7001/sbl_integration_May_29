        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="import * as random from 'random';&amp;#10;stimuli = [[&quot;TESTstimuli/TESTscenes/JA_3.jpg&quot;, &quot;Tulon&quot;], [&quot;TESTstimuli/TESTscenes/JB_3.jpg&quot;, &quot;Malbow&quot;], [&quot;TESTstimuli/TESTscenes/UA_3.jpg&quot;, &quot;Negvi&quot;], [&quot;TESTstimuli/TESTscenes/UB_3.jpg&quot;, &quot;Somar&quot;]];&amp;#10;Math.random.shuffle(stimuli);&amp;#10;[img1_2.image, label1_2.text] = stimuli[0];&amp;#10;[img2_2.image, label2_2.text] = stimuli[1];&amp;#10;[img3_2.image, label3_2.text] = stimuli[2];&amp;#10;[img4_2.image, label4_2.text] = stimuli[3];&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="&amp;#10;# fixed image paths&amp;#10;JA_img = &quot;stimuli/scenes/JA_1.jpg&quot;&amp;#10;JB_img = &quot;stimuli/scenes/JB_3.jpg&quot;&amp;#10;UA_img = &quot;stimuli/scenes/UA_1.jpg&quot;&amp;#10;UB_img = &quot;stimuli/scenes/UB_2.jpg&quot;&amp;#10;&amp;#10;# labels pulled from condition list variables created in Begin Experiment&amp;#10;JA_lbl = scene_JA_lbl&amp;#10;JB_lbl = scene_JB_lbl&amp;#10;UA_lbl = scene_UA_lbl&amp;#10;UB_lbl = scene_UB_lbl&amp;#10;&amp;#10;# fixed layout&amp;#10;img1_2.image = JA_img&amp;#10;label1_2.text = JA_lbl&amp;#10;&amp;#10;img2_2.image = JB_img&amp;#10;label2_2.text = JB_lbl&amp;#10;&amp;#10;img3_2.image = UA_img&amp;#10;label3_2.text = UA_lbl&amp;#10;&amp;#10;img4_2.image = UB_img&amp;#10;label4_2.text = UB_lbl" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
