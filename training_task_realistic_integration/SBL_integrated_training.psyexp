        <Param val="# load the participant's scene-name mapping&amp;#10;cond_file = &quot;stimuli/cond_lists/scene_names_sub_&quot; + expInfo['participant'] + &quot;.csv&quot;&amp;#10;df = pd.read_csv(cond_file)&amp;#10;&amp;#10;# build dictionary mapping scene code -&gt; label&amp;#10;labels = dict(zip(df['scene_stimulus'], df['scene_label']))&amp;#10;&amp;#10;# Jungle scene labels&amp;#10;if key_JA == '1':&amp;#10;    jungle_lbl_text = '1.' + labels['JA'] + '\n2.' + labels['JB']&amp;#10;else:&amp;#10;    jungle_lbl_text = '1.' + labels['JB'] + '\n2.' + labels['JA']&amp;#10;&amp;#10;# Undersea scene labels&amp;#10;if key_UA == '1':&amp;#10;    sea_lbl_text = '1.' + labels['UA'] + '\n2.' + labels['UB']&amp;#10;else:&amp;#10;    sea_lbl_text = '1.' + labels['UB'] + '\n2.' + labels['UA']" valType="extendedCode" updates="constant" name="Begin Routine"/>
