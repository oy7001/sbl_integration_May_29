      <Param name="name" updates="None" val="part4_loop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="item_imagine_scene"/>
    <Routine name="p4_blank1000"/>
    <Routine name="select_context"/>
    <Routine name="blank500"/>
    <Routine name="context_confidence"/>
    <Routine name="p4_blank1000"/>
    <Routine name="select_scene_name"/>
    <Routine name="blank500"/>
    <Routine name="select_confidence"/>
    <Routine name="blank_3000"/>
    <LoopTerminator name="part4_loop"/>
    <Routine name="end_screen"/>
  </Flow>
</PsychoPy2experiment>
