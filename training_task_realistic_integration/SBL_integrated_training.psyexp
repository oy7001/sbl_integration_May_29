        <Param val="Welcome to the items and scenes memory experiment!&amp;#10;&amp;#10;In this first task, you will learn the names and visual details of four scenes.&amp;#10;&amp;#10;You will then practice visualizing the scenes in detail.&amp;#10;&amp;#10;Finally, you will have a short practice run of the next tasks which you will undertake later in the study session.&amp;#10;&amp;#10;Press SPACEBAR to continue." valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
