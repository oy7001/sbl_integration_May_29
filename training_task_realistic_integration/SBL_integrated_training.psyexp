        <Param val="if ((key_jungle === &quot;1&quot;)) {&amp;#10;    context_jungle_txt = (&quot;1. &quot; + &quot;Jungle&quot;);&amp;#10;    pos_jungle = [0, 0.06];&amp;#10;    context_sea_txt = (&quot;2. &quot; + &quot;Undersea&quot;);&amp;#10;    pos_sea = [0, 0];&amp;#10;} else {&amp;#10;    if ((key_jungle === &quot;2&quot;)) {&amp;#10;        context_sea_txt = (&quot;1. &quot; + &quot;Undersea&quot;);&amp;#10;        pos_sea = [0, 0.06];&amp;#10;        context_jungle_txt = (&quot;2. &quot; + &quot;Jungle&quot;);&amp;#10;        pos_jungle = [0, 0];&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
