        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Part 1.&amp;#10;In this part, you will learn about four scenes.&amp;#10;&amp;#10;Please pay attention to the name and to the visual details of each scene. There are three images for each scene, so focus on the consistent characteristics of each scene. The name will appear above the image.&amp;#10;&amp;#10;Press SPACEBAR to go to the next scene after you have fully learned the current scene.&amp;#10;&amp;#10;You will be asked to name and visualize them in detail later on.&amp;#10;&amp;#10;Press SPACEBAR to continue." valType="str" updates="constant" name="text"/>
