      <Param name="conditionsFile" updates="None" val="$'stimuli/stim_lists/stimuli_list_sub_' + str(int(expInfo['participant'])) + '_run_1.csv'" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
